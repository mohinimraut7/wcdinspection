APP_NAME="WCD Inspection"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stack

# ── Database (MySQL) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wcd_inspection
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT Secret (same as Node.js JWT_SECRET) ──
JWT_SECRET=MySuperSecretKey123!

# ── Cache / Session ──
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
